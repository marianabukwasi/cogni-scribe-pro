# ─── Kloer.ai Environment Variables ─────────────────────
# Copy this file to .env and fill in the values.

# ─── Supabase (auto-provisioned by Lovable Cloud) ──────
VITE_SUPABASE_URL=           # Your Supabase project URL  (Settings → API in Supabase dashboard)
VITE_SUPABASE_PUBLISHABLE_KEY=  # Supabase anon/publishable key (Settings → API → anon public)
VITE_SUPABASE_PROJECT_ID=       # Supabase project ID (Settings → General)

# ─── Supabase Edge Function Secrets ─────────────────────
# Configured via Lovable Cloud secrets, NOT in this file.
# Listed here for reference only.

# DEEPGRAM_API_KEY=          # Get from https://console.deepgram.com → API Keys
#                            # Required for live transcription in sessions

# LOVABLE_API_KEY=           # Auto-provisioned by Lovable Cloud — powers AI features
#                            # (No manual setup needed)

# SUPABASE_SERVICE_ROLE_KEY= # Auto-provisioned — used in edge functions for admin access
#                            # (No manual setup needed)

# ─── Stripe (for subscription billing) ──────────────────
# STRIPE_PUBLISHABLE_KEY=    # Get from https://dashboard.stripe.com/apikeys → Publishable key
#                            # Safe to use in frontend code
# STRIPE_SECRET_KEY=         # Get from https://dashboard.stripe.com/apikeys → Secret key
#                            # Edge function secret only — NEVER expose in frontend
# STRIPE_WEBHOOK_SECRET=     # Get from https://dashboard.stripe.com/webhooks → Signing secret
#                            # Edge function secret only
