# ─── Kloer.ai Environment Variables ─────────────────────
# Copy this file to .env and fill in the values.

# ─── Supabase (auto-provisioned by Lovable Cloud) ──────
VITE_SUPABASE_URL=           # Your Supabase project URL
VITE_SUPABASE_PUBLISHABLE_KEY=  # Your Supabase anon/publishable key

# ─── Supabase Edge Function Secrets ─────────────────────
# These are configured via Lovable Cloud or Supabase dashboard,
# NOT in this file. Listed here for reference only.

# DEEPGRAM_API_KEY=          # Get from deepgram.com — required for live transcription
# LOVABLE_API_KEY=           # Auto-provisioned by Lovable Cloud — powers AI features
# SUPABASE_SERVICE_ROLE_KEY= # Auto-provisioned — used in edge functions for admin access

# ─── Future Integrations (not yet implemented) ─────────
# STRIPE_PUBLISHABLE_KEY=    # Get from stripe.com — required for payments (P1)
# STRIPE_SECRET_KEY=         # Stripe secret — edge function only, never in frontend
